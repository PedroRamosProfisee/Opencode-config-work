{
  "$schema": "https://opencode.ai/config.json",
  "server": {
    "port": 4096
  },
  "instructions": [
    "rules/bash-safety.md",
    "rules/context-management.md",
    "rules/patterns-common.md",
    "rules/learner-communication-preferences.md",
    "rules/vibe-coding-summary.md",
    "If a file named `.codesight/CODESIGHT.md` exists in the project root, read it at the start of the session and use it as a file and symbol index. Do not read it automatically if it does not exist.",
    "When unclear on requirements, use AUQ (ask-user-questions) MCP tool instead of guessing. Batch multiple questions into one call. Never guess when you can ask."
  ],
  "plugin": [
    "opencode-notify",
    "@cortexkit/opencode-magic-context"
  ],
  "compaction": {
    "auto": false,
    "prune": false,
    "reserved": 20000
  },
  "permission": {
    "edit": "allow",
    "bash": "ask"
  },
  "mcp": {
    "ado": {
      "type": "local",
      "command": ["npx", "-y", "@azure-devops/mcp@next", "profisee", "-d", "core", "work-items", "repositories", "pipelines", "wiki", "test-plans", "search"],
      "enabled": true
    },
    "codesight": {
      "type": "local",
      "command": [
        "npx",
        "codesight",
        "--mcp"
      ],
      "timeout": 30000
    }
  },
  "provider": {
    "cheap-cloud": {
      "npm": "@ai-sdk/openai",
      "name": "Cheap Cloud",
      "models": {
        "gpt-4o-mini": {
          "name": "GPT-4o Mini",
          "prompt": "prompts/core/openagent/gpt-mini-implementor.md"
        }
      }
    }
  }
}
