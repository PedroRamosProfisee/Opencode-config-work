{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/claude-opus-4.6",
  "agent": {
    "build": {
      "mode": "primary",
      "model": "github-copilot/claude-opus-4.6"
    },
    "plan": {
      "mode": "primary",
      "model": "github-copilot/claude-sonnet-4.5"
    }
  },
  "plugin": [
    "opencode-notify",
    "@cortexkit/opencode-magic-context"
  ],
  "compaction": {
    "auto": false,
    "prune": false
  },
  "permission": {
    "edit": "allow",
    "bash": "ask"
  }
}
