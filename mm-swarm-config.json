    "corePipeline":  {
                         "C1":  "PLAN",
                         "C2":  "INSTRUCT",
                         "C3":  "EXECUTE",
                         "C4":  "REVIEW",
                         "C5":  "TEST"
                     },
    "smartAUQ":  {
                     "ALWAYS":  "Pipeline entry (2-step: tier + Go/Modify/Cancel)",
                     "CONDITIONAL":  "Plan review (complex tasks), ambiguity \u003c 0.5, post-rejection after 2 retries, migration/security plans",
                     "NEVER":  "Between instruct/execute, during execute, between test-write/test-run, Trivial tasks",
                     "confidenceThresholds":  {
                                                  "auto":  0.8,
                                                  "proceedWithFlag":  0.5,
                                                  "stop":  0.0
                                              }
                 },
    "pricing":  {
                    "gpt-5.5":  {
                                    "input":  0,
                                    "output":  0,
                                    "unit":  "flatRate",
                                    "note":  "Copilot subscription; use reasoningEffort=xhigh for high-effort agents"
                                },
                    "claude-sonnet-4.6":  {
                                              "input":  0.003,
                                              "output":  0.015,
                                              "unit":  "per1KTokens"
                                          },
                    "claude-haiku-4.5":  {
                                             "input":  0.0008,
                                             "output":  0.004,
                                             "unit":  "per1KTokens"
                                         },
