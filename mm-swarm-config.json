                     "gemini-2.5-pro":  {
                                            "input":  0,
                                            "output":  0,
                                            "unit":  "freeTier"
                                        }
                 },
    "phaseSummarySchema":  {
                               "ph":  "string — phase name (investigation|planning|instruction|review|execution|testing|debugging)",
                               "rid":  "string — runId",
                               "ts":  "ISO 8601 — completedAt",
                               "s":  "string — status (ok|err|warn)",
                               "kf":  [
                                          "max 5 items, ~200 tokens total — keyFindings"
                                      ],
                               "np":  "string — nextPhase",
                               "rdy":  "boolean — readyForHandoff",
                               "_optional":  {
                                                 "cx":  "string — complexity (trivial|simple|moderate|complex|architectural)",
                                                 "f":  [
                                                           "array — files involved"
                                                       ],
                                                 "iss":  [
                                                             "array — issues if s=err or s=warn"
                                                         ],
                                                 "dec":  [
                                                             {
                                                                 "id":  "string",
                                                                 "txt":  "string"
                                                             }
                                                         ]
                                             }
                           }
}
